{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/pgill-dev/Daedalus/schemas/validation-checklist.schema.json",
  "title": "Daedalus Validation Checklist",
  "type": "object",
  "required": [
    "date",
    "author",
    "status",
    "risk_level",
    "summary",
    "pre_change_validation",
    "post_change_validation",
    "negative_validation",
    "rollback_validation",
    "human_approval_gate"
  ],
  "properties": {
    "date": {
      "type": "string",
      "format": "date"
    },
    "author": {
      "type": "string",
      "const": "Daedalus"
    },
    "status": {
      "type": "string",
      "enum": ["Proposed", "Human Reviewed", "Completed", "Failed", "Superseded"]
    },
    "related_request": {
      "type": "string"
    },
    "related_package": {
      "type": "string"
    },
    "risk_level": {
      "type": "string",
      "enum": ["Low", "Medium", "High", "Critical"]
    },
    "summary": {
      "type": "string"
    },
    "pre_change_validation": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "post_change_validation": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "negative_validation": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "rollback_validation": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "human_approval_gate": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "follow_up_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "required": ["id", "check", "expected_result", "evidence", "result", "notes"],
      "properties": {
        "id": {
          "type": "string"
        },
        "check": {
          "type": "string"
        },
        "expected_result": {
          "type": "string"
        },
        "evidence": {
          "type": "string"
        },
        "result": {
          "type": "string",
          "enum": ["Not Tested", "Pass", "Fail", "Blocked", "Not Applicable"]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
